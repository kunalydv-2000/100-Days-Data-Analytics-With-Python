   "source": [
    "# String Slicing\n",
    "Slicing extracts part of a string."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "ab1f8e6d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Pyth\n"
     ]
    }
   ],
   "source": [
    "name = \"Python\"\n",
    "\n",
    "print(name[0:4])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "f45749a5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Data\n",
      "Analytics\n",
      "Data\n",
      "Analytics\n"
     ]
    }
   ],
   "source": [
    "name = \"DataAnalytics\"\n",
    "\n",
    "print(name[0:4])\n",
    "print(name[4:13])\n",
    "print(name[:4])\n",
    "print(name[4:])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2b7f6539",
   "metadata": {},
   "source": [
